# Copy to .env.local (local) or set in Vercel Project Settings (production / preview).

# Public site URL (no trailing slash). Used for canonical URLs and Open Graph absolute links.
# Production: https://your-domain.com  |  Vercel preview often works without this (falls back to VERCEL_URL).
NEXT_PUBLIC_SITE_URL=

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Dashboard > Authentication > URL Configuration
# - Site URL: your primary app URL (e.g. https://your-app.vercel.app or custom domain)
# - Redirect URLs: list every origin that must complete OAuth, each with /auth/callback, e.g.:
#   http://localhost:3000/auth/callback
#   https://your-app.vercel.app/auth/callback
#   https://*.vercel.app/auth/callback   (wildcard — covers Preview deployments)
#
# Google: Authentication > Providers > Google (OAuth client from Google Cloud Console)
