# Copy to .env.local and fill in your Supabase project credentials (Settings > API)

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Dashboard > Authentication > URL Configuration:
# - Site URL: http://localhost:3000 (production: your real URL)
# - Redirect URLs: http://localhost:3000/auth/callback
#
# Enable Google under Authentication > Providers > Google (Client ID/Secret from Google Cloud Console)
